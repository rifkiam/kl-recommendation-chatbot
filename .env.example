PORT=3000
CHROMA_URL=http://localhost:8000

# Vector collection name (re-run `npm run seed` after changing EMBEDDING_* or CHROMA_COLLECTION)
# CHROMA_COLLECTION=example_collection

# Embeddings: `local` (default, free, multilingual MiniLM via transformers.js) or `ollama`
# EMBEDDING_BACKEND=local

# Local model (SBERT-style; Xenova ONNX builds). Higher quality option:
# EMBEDDING_MODEL=Xenova/paraphrase-multilingual-mpnet-base-v2
# EMBEDDING_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2

# When EMBEDDING_BACKEND=ollama — pull first, e.g. `ollama pull nomic-embed-text`
# OLLAMA_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text

# Chat answer synthesis (POST /api/chat): pull a chat model, e.g. `ollama pull llama3.2`
# OLLAMA_CHAT_MODEL=llama3.2

# Chat retrieval: wide pool from Chroma, then intent-aware reorder + top-N response
# CHAT_RETRIEVAL_POOL=40
# CHAT_RESPONSE_TOP=5

# Golden RAG check (npm run check:rag): min pass rate 0–1
# RAG_ACCURACY_MIN=0.75
# RAG_EVAL_TOP_N=5
# Also verify Ollama replies vs rag-golden.json expectReplyContainsAny (all must pass)
# RAG_CHECK_OLLAMA=1